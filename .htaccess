# jobid.ai — Apache .htaccess (IONOS)
# Stand 2026-06-28

RewriteEngine On

# === Clean URLs: .html ausblenden ===
# /pfad/index.html -> /pfad/
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
# /pfad/seite.html -> /pfad/seite (Google-Verifizierung ausgenommen)
RewriteCond %{REQUEST_URI} !^/google[0-9a-zA-Z]+\.html$ [NC]
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
# clean -> Datei ausliefern, auch wenn gleichnamiger Ordner existiert
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
